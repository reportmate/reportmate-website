---
import Layout from '../layouts/Layout.astro';

// The full platform ships in every tier — no feature paywalls. Plans differ
// only by who runs it, how it scales, and the level of support behind it.
const includedEverywhere = 'The complete platform — every data module, full REST API and webhooks, SSO / SAML, real-time dashboard. No feature paywalls.';

const tiers = [
  {
    name: 'Self-Hosted',
    price: 'Free',
    period: 'forever',
    description: 'Run the whole platform on your own infrastructure.',
    features: [
      'Unlimited endpoints',
      'Every data module',
      'Full REST API & webhooks',
      'SSO / SAML',
      'Terraform modules (Azure + AWS)',
      'Real-time dashboard',
      'Community support (GitHub)',
      'Source-available (BSL 1.1)',
    ],
    cta: 'Get Started on GitHub',
    ctaLink: 'https://github.com/reportmate',
    highlighted: false,
  },
  {
    name: 'Cloud Starter',
    price: '$99',
    period: '/month',
    annualNote: 'or $990/year — 2 months free',
    description: 'We host, upgrade, and back it up. You manage your fleet.',
    features: [
      'Up to 100 endpoints',
      'Full platform — fully managed',
      'Managed hosting & automatic upgrades',
      'Daily backups + SSL included',
      'Email support',
    ],
    cta: 'Join the Waitlist',
    ctaLink: 'mailto:hello@reportmate.app?subject=ReportMate%20Cloud%20Starter%20waitlist',
    highlighted: true,
    badge: 'Early access',
  },
  {
    name: 'Cloud Pro',
    price: '$499',
    period: '/month',
    annualNote: 'or $4,990/year — 2 months free',
    description: 'Managed at scale, with isolation and priority support.',
    features: [
      'Unlimited endpoints',
      'Everything in Starter',
      'Single-tenant isolation',
      'Custom data retention',
      'Uptime SLA',
      'Priority support',
    ],
    cta: 'Join the Waitlist',
    ctaLink: 'mailto:hello@reportmate.app?subject=ReportMate%20Cloud%20Pro%20waitlist',
    highlighted: false,
    badge: 'Early access',
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'Dedicated or on-premise, with a white-glove support package built in.',
    features: [
      'Everything in Pro',
      'Dedicated infrastructure or on-premise',
      'Response-time SLA',
      'Named phone + Slack support',
      'Custom integrations',
      'Onboarding & migration included',
    ],
    cta: 'Contact Sales',
    ctaLink: 'mailto:hello@reportmate.app?subject=ReportMate%20Enterprise',
    highlighted: false,
  },
];

// Human services, sold as a package on top of any plan — including self-hosted.
const services = [
  {
    title: 'Installation & configuration',
    desc: 'We stand ReportMate up in your cloud or on-premise, wire in SSO, and tune collection to your fleet.',
  },
  {
    title: 'Guided migration',
    desc: 'Move off MunkiReport, Sal, or spreadsheets without losing history — we map and import your existing data.',
  },
  {
    title: 'Ongoing support & SLA',
    desc: 'Named phone and Slack support with response-time guarantees, whether we host it or you do.',
  },
];

const faqs = [
  {
    q: 'Is the self-hosted version really free?',
    a: 'Yes. The full platform — clients, API, dashboard, and Terraform — is source-available under BSL 1.1. Run it on unlimited endpoints in your own cloud at no license cost. The paid plans exist for teams who would rather we operate it for them.',
  },
  {
    q: 'Where does my fleet data live?',
    a: 'On self-hosted and Enterprise, entirely in infrastructure you own — telemetry never transits our servers. On managed Cloud plans, in a tenant we operate on your behalf, with daily backups and SSL. Either way the data is plain PostgreSQL you can query and export.',
  },
  {
    q: 'What does BSL 1.1 mean for me?',
    a: 'The Business Source License lets you read, run, audit, modify, and self-host ReportMate freely for your own fleet. The only restriction is offering ReportMate itself as a competing hosted service. Each release converts to a fully open license over time.',
  },
  {
    q: 'Can I start self-hosted and move to managed later?',
    a: 'Yes. Because both run the same code and the same PostgreSQL schema, migrating between self-hosted and managed Cloud is a data move, not a re-platform. Enterprise onboarding includes a guided migration.',
  },
  {
    q: 'How does endpoint counting work?',
    a: 'An endpoint is any Macintosh or Windows device reporting in. Self-hosted and Enterprise are unlimited. Cloud Starter is capped at 100 active devices; Cloud Pro is unlimited.',
  },
  {
    q: 'I want to self-host but still get help — can I?',
    a: "Yes. Installation, configuration, and support are available as a package whether you run ReportMate yourself or let us manage it. We'll stand up your deployment, tune it to your fleet, migrate you off MunkiReport or Sal, and stay on call — without you giving up control of your data.",
  },
  {
    q: 'What does an Enterprise engagement include?',
    a: 'A scoped package: hands-on installation and configuration, guided migration from MunkiReport, Sal, or spreadsheets, a dedicated instance (managed by us or on-premise), an SLA, and named phone and Slack support. We size each engagement to your fleet — talk to us and we will put together a quote.',
  },
];
---

<Layout title="Pricing — ReportMate" description="Self-host ReportMate free on unlimited endpoints, or run it managed. Transparent, open-core pricing for Macintosh and Windows fleets.">
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-6 py-20 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">Simple, transparent pricing</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
        Self-host the whole platform free, forever, on unlimited endpoints. Or let us run it for you. No per-seat
        traps, no locking your own data behind a paywall.
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {tiers.map((tier) => (
          <div
            class:list={[
              'relative flex flex-col rounded-xl border p-8',
              tier.highlighted ? 'border-brand-500 shadow-lg shadow-brand-500/10' : 'border-gray-200',
            ]}
          >
            {tier.badge && (
              <span class="absolute -top-3 left-8 rounded-full bg-brand-600 px-3 py-1 text-xs font-medium text-white">
                {tier.badge}
              </span>
            )}
            <h3 class="text-lg font-semibold text-gray-900">{tier.name}</h3>
            <div class="mt-4">
              <span class="text-4xl font-bold text-gray-900">{tier.price}</span>
              {tier.period && <span class="text-gray-500">{tier.period}</span>}
            </div>
            {tier.annualNote && <p class="mt-1 text-xs font-medium text-brand-600">{tier.annualNote}</p>}
            <p class="mt-2 text-sm text-gray-600">{tier.description}</p>

            <ul class="mt-8 flex-1 space-y-3">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={tier.ctaLink}
              class:list={[
                'mt-8 block rounded-lg px-4 py-2.5 text-center text-sm font-medium',
                tier.highlighted ? 'bg-brand-600 text-white hover:bg-brand-700' : 'border border-gray-300 text-gray-700 hover:bg-gray-50',
              ]}
            >
              {tier.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platform note + Services & support -->
  <section class="bg-white pb-24">
    <div class="mx-auto max-w-6xl space-y-8 px-6">
      <div class="rounded-2xl border border-gray-200 bg-gray-50 px-8 py-10 text-center">
        <p class="mx-auto max-w-3xl text-base text-gray-600">
          {includedEverywhere} You pay for who runs it, how it scales, and the support behind it — never to unlock your own data.
        </p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white shadow-lg shadow-brand-500/10">
        <div class="p-8 sm:p-12">
          <div class="max-w-2xl">
            <span class="inline-flex items-center rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold text-white">
              Services &amp; support
            </span>
            <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900">
              We'll install it, migrate you, and stay on call
            </h2>
            <p class="mt-4 text-lg text-gray-600">
              Self-hosting or managed, our team can stand ReportMate up for your fleet, move you off your old
              tooling, and back it with an SLA. Support is a package you add to any plan — not a tier you're forced
              to climb to.
            </p>
          </div>

          <div class="mt-10 grid gap-8 md:grid-cols-3">
            {services.map((service) => (
              <div class="rounded-xl border border-brand-100 bg-white/70 p-6">
                <h3 class="text-base font-semibold text-gray-900">{service.title}</h3>
                <p class="mt-2 text-sm text-gray-600">{service.desc}</p>
              </div>
            ))}
          </div>

          <div class="mt-10">
            <a href="mailto:hello@reportmate.app?subject=ReportMate%20services%20%26%20support" class="inline-block rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-700">
              Talk to us about a package
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-gray-100 bg-gray-50 py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="text-center text-3xl font-bold text-gray-900">Frequently asked</h2>
      <div class="mt-12 space-y-8">
        {faqs.map(({ q, a }) => (
          <div>
            <h3 class="font-semibold text-gray-900">{q}</h3>
            <p class="mt-2 text-gray-600">{a}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <p class="text-gray-600">Still have questions about a rollout?</p>
        <a href="mailto:hello@reportmate.app" class="mt-3 inline-block rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-700">
          Talk to us
        </a>
      </div>
    </div>
  </section>
</Layout>
