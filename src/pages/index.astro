---
import Layout from '../layouts/Layout.astro';
import BarsMark from '../components/dataviz/BarsMark.astro';
import DonutMark from '../components/dataviz/DonutMark.astro';
import Sparkline from '../components/dataviz/Sparkline.astro';
import { modules } from '../data/modules.js';

// Per-letter colors for the highlighted hero word, cycling the logo's
// bar/donut palette so the word reads like the logo's bar graph.
const barColors = ['#0074c7', '#e0533a', '#f08a00', '#f4b400', '#16a596', '#7a4fa0'];
const barWord = 'reporting';



const attributions = [
  { name: 'osquery', desc: 'The SQL-powered engine behind on-device collection.', href: 'https://www.osquery.io' },
  { name: 'FastAPI', desc: 'Powers the event ingest and REST API.', href: 'https://fastapi.tiangolo.com' },
  { name: 'Next.js', desc: 'Renders the real-time fleet dashboard.', href: 'https://nextjs.org' },
  { name: 'PostgreSQL', desc: 'JSONB storage — one document per module.', href: 'https://www.postgresql.org' },
  { name: 'Terraform', desc: 'Provisions ReportMate into Azure or AWS.', href: 'https://www.terraform.io' },
  { name: 'Munki', desc: 'Macintosh managed installs, surfaced in the Installs module.', href: 'https://www.munki.org' },
  { name: 'Cimian', desc: 'Windows managed installs, surfaced in the Installs module.', href: 'https://github.com/windowsadmins/cimian' },
];

const shots = [
  { src: '/devices-report.webp', cap: 'Fleet device list' },
  { src: '/security-report.webp', cap: 'Security posture' },
  { src: '/network-report.webp', cap: 'Network & Wi-Fi' },
  { src: '/application-report.webp', cap: 'Application inventory' },
  { src: '/device-installs.webp', cap: 'Managed installs' },
  { src: '/events-report.webp', cap: 'Live event stream' },
];
---

<Layout title="ReportMate — Open-Source Endpoint Intelligence for Macintosh & Windows">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-6 pb-24 pt-8 text-center">
      <img src="/reportmate-logo.png" alt="ReportMate" width="288" height="288" class="mx-auto mb-4 h-56 w-56 sm:h-72 sm:w-72" />
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl">
        Your whole fleet.<br />
        Always <span class="font-extrabold">{barWord.split('').map((ch, i) => (
          <span style={`color:${barColors[i % barColors.length]}`}>{ch}</span>
        ))}</span> in.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
        ReportMate is open-source endpoint intelligence for Macintosh and Windows. Native clients do the heavy
        collection and processing <strong class="font-semibold text-gray-900">on each device</strong>, then stream events to an API and database <strong class="font-semibold text-gray-900">you control</strong> — no
        agents phoning home to a vendor.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="https://demo.reportmate.app" class="rounded-lg bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-sm shadow-accent-500/25 hover:bg-accent-600">
          Explore the Live Demo
        </a>
        <a href="https://github.com/reportmate" class="rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
          View on GitHub
        </a>
      </div>
      <p class="mt-6 text-sm text-gray-500">
        Deploy to your own Azure or AWS tenant with Terraform — <span class="font-semibold text-accent-500">or let us run it for you.</span>
      </p>

      <div class="mx-auto mt-16 max-w-5xl">
        <img
          src="/dashboard.webp"
          alt="ReportMate fleet dashboard showing device counts, live events, and platform distribution"
          width="2494"
          height="1832"
          class="w-full cursor-zoom-in"
          loading="eager"
          data-lightbox
        />
      </div>
    </div>
  </section>

  <!-- Positioning strip -->
  <section class="border-y border-gray-100 bg-gradient-to-b from-white to-brand-50/40">
    <div class="mx-auto grid max-w-6xl divide-y divide-gray-200/70 px-6 sm:grid-cols-2 sm:divide-y-0 lg:grid-cols-4 lg:divide-x">
      {[
        { stat: '10', label: 'Data modules per device', color: '#0074c7', mark: 'bars' },
        { stat: '2', label: 'First-class platforms: Macintosh & Windows', color: '#f08a00', mark: 'donut' },
        { stat: '40+', label: 'Versioned REST API endpoints', color: '#16a596', mark: 'spark' },
        { stat: '100%', label: 'Open source and self-hostable', color: '#7a4fa0', mark: 'donut' },
      ].map(({ stat, label, color, mark }) => (
        <div class="px-6 py-10 text-center">
          <div class="mb-3 flex h-6 items-center justify-center">
            {mark === 'bars' && <BarsMark class="h-6 w-6" />}
            {mark === 'donut' && <DonutMark class="h-6 w-6" />}
            {mark === 'spark' && <Sparkline class="h-6 w-16" color={color} />}
          </div>
          <div class="text-5xl font-extrabold tracking-tight" style={`color:${color}`}>{stat}</div>
          <div class="mx-auto mt-2 max-w-[12rem] text-sm font-medium text-gray-500">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Ten reports (moved above the diagram, upgraded) -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-1.5 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
          <BarsMark class="h-3.5 w-3.5" /> Unified telemetry
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Everything a device knows about itself.<br class="hidden sm:block" /> Identical on Mac and Windows.
        </h2>
        <p class="mt-5 text-lg text-gray-600">
          Every check-in refreshes a full set of module reports, built and normalized on the endpoint to one shared
          schema. Not two tools bolted together — one genuinely unified fleet view.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
        {modules.map(({ name, short, accent, icon }) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-brand-200 hover:shadow-lg">
            <div class:list={['flex h-11 w-11 items-center justify-center rounded-xl', accent]}>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="h-6 w-6">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="mt-4 font-semibold text-gray-900">{name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">{short}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/features" class="text-sm font-medium text-brand-600 hover:text-brand-700">
          See every field each module collects &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- A closer look (real screenshots) -->
  <section class="border-y border-gray-100 bg-gray-50 py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center rounded-full border border-brand-200 bg-white px-3 py-1 text-xs font-medium text-brand-700">
          A closer look
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">From fleet overview to a single chip</h2>
        <p class="mt-5 text-lg text-gray-600">
          Start at the fleet level, then drill into any device for every module — hardware down to the SoC,
          security posture, network, managed installs, and more.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl">
        <img
          src="/device-hardware.webp"
          alt="ReportMate device hardware view showing CPU, memory, storage, battery, GPU and NPU"
          width="2494"
          height="1832"
          class="w-full cursor-zoom-in"
          loading="lazy"
          data-lightbox
        />
      </div>

      <div class="mt-8 grid gap-x-6 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
        {shots.map(({ src, cap }) => (
          <figure>
            <img src={src} alt={cap} width="2494" height="1832" class="w-full cursor-zoom-in" loading="lazy" data-lightbox />
            <figcaption class="mt-2 text-center text-sm font-medium text-gray-600">{cap}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Architecture teaser -->
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Curious how it all fits together?</h2>
      <p class="mt-3 text-lg text-gray-600">
        Native binaries on the endpoint, an event-driven REST API, a JSONB store, and real-time push — all deployed
        in your own cloud.
      </p>
      <a href="/architecture" class="mt-6 inline-flex items-center gap-1.5 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700">
        See the architecture
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" /></svg>
      </a>
    </div>
  </section>

  <!-- Why ReportMate -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Built for teams that want control</h2>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        <div class="rounded-2xl border border-gray-100 p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Truly cross-platform</h3>
          <p class="mt-2 text-gray-600">
            One schema, one dashboard, one API for Macintosh and Windows. No reconciling two products with different data
            models and different bills.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-100 p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Your data, your cloud</h3>
          <p class="mt-2 text-gray-600">
            Self-host or deploy to your own Azure/AWS tenant with the included Terraform. Telemetry never transits a
            vendor's servers. Encrypted in transit, passphrase-authenticated.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-100 p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Open source, no lock-in</h3>
          <p class="mt-2 text-gray-600">
            Source-available under BSL 1.1. Read the code, audit the collection, extend a module, or fork it. Your
            data lives in plain PostgreSQL you can query directly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Built on open source -->
  <section class="border-t border-gray-100 bg-gray-50 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Built on open source</h2>
        <p class="mt-4 text-gray-600">
          ReportMate stands on the shoulders of the tools our community already trusts — and integrates with the
          managed-software systems you may already run.
        </p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {attributions.map(({ name, desc, href }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md"
          >
            <div class="flex items-center justify-between">
              <h3 class="font-semibold text-gray-900">{name}</h3>
              <svg class="h-4 w-4 text-gray-300 transition group-hover:text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-900 py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to take control of your fleet?</h2>
      <p class="mt-4 text-lg text-gray-300">
        Click around the live demo, or deploy your own in an afternoon. Self-host for free, or let us run it.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="https://demo.reportmate.app" class="rounded-lg bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-sm shadow-accent-500/25 hover:bg-accent-600">
          Explore the Live Demo
        </a>
        <a href="/pricing" class="rounded-lg border border-gray-600 px-6 py-3 text-sm font-medium text-white hover:bg-gray-800">
          See Pricing
        </a>
      </div>
    </div>
  </section>
</Layout>
