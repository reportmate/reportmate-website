---
import Layout from '../layouts/Layout.astro';
import Mermaid from '../components/Mermaid.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import { modules } from '../data/modules.js';

const archDiagram = `flowchart TB
  subgraph EP["① &nbsp;ENDPOINTS — collect &amp; process on-device"]
    direction LR
    MAC["<b>macOS</b><br/>native Swift binary<br/><small>launchd · signed &amp; notarized</small>"]
    OSQ(["<b>osquery</b><br/>+ macadmins extension<br/>+ native OS APIs"])
    WIN["<b>Windows</b><br/>C# / .NET binary<br/><small>service + task · signed</small>"]
    MAC --- OSQ
    OSQ --- WIN
  end

  PAY{{"<b>one signed event payload</b><br/>10 module documents<br/><small>hardware · system · network · security · applications<br/>installs · inventory · management · identity · peripherals</small>"}}
  EP ==> PAY

  subgraph CLOUD["② &nbsp;YOUR CLOUD — Terraform on Azure or AWS"]
    direction LR
    API["<b>FastAPI</b><br/>ingest + REST /api/v1<br/><small>40+ endpoints · OpenAPI</small>"]
    DB[("<b>PostgreSQL</b><br/>JSONB per module")]
    RT(["<b>SignalR / Web PubSub</b><br/>real-time push"])
    API --> DB
    API --> RT
  end
  PAY ==>|"HTTPS POST /api/v1/events<br/>X-Client-Passphrase"| API

  subgraph READ["③ &nbsp;READ — web, native &amp; your tools"]
    direction LR
    WEB["<b>Next.js dashboard</b><br/><small>live fleet view</small>"]
    APPS["<b>Native Mac &amp; Windows apps</b><br/><small>coming soon</small>"]
    INT["<b>CMDB · SIEM · automation</b><br/><small>via REST API</small>"]
  end
  DB ==> WEB
  RT ==> WEB
  DB ==> APPS
  RT ==> APPS
  API ==> INT

  classDef ep fill:#eff6ff,stroke:#2563eb,stroke-width:2px,color:#1e3a8a;
  classDef pay fill:#0074c7,stroke:#015da1,stroke-width:2.5px,color:#ffffff;
  classDef cloud fill:#ecfdf5,stroke:#059669,stroke-width:2px,color:#065f46;
  classDef read fill:#fff7ed,stroke:#ea580c,stroke-width:2px,color:#9a3412;
  class MAC,WIN,OSQ ep;
  class PAY pay;
  class API,DB,RT cloud;
  class WEB,APPS,INT read;

  style EP fill:#f8fafc,stroke:#cbd5e1,color:#334155;
  style CLOUD fill:#f8fafc,stroke:#cbd5e1,color:#334155;
  style READ fill:#f8fafc,stroke:#cbd5e1,color:#334155;`;

const curlExample = `$ curl https://api.reportmate.app/api/v1/devices \\
    -H "X-Client-Passphrase: $RM_KEY"

{
  "devices": [
    {
      "serialNumber": "C02XL0ABJGH7",
      "deviceId": "9f2a1c7e-4b30-4d2a-bf1e-7c0a2d51e8a4",
      "name": "design-studio-04",
      "platform": "Macintosh",
      "osName": "macOS",
      "osVersion": "15.5",
      "assetTag": "ECU-04821",
      "department": "Design",
      "status": "active",
      "lastSeen": "2026-06-18T17:42:11Z",
      "totalEvents": 1284
    }
  ],
  "total": 327,
  "hasMore": false
}`;

const attributions = [
  { name: 'osquery', desc: 'The SQL-powered engine behind on-device collection.', href: 'https://www.osquery.io' },
  { name: 'MacAdmins osquery extension', desc: 'Extra macOS tables for richer Mac telemetry.', href: 'https://github.com/macadmins/osquery-extension' },
  { name: 'FastAPI', desc: 'Powers the event ingest and REST API.', href: 'https://fastapi.tiangolo.com' },
  { name: 'Next.js', desc: 'Renders the real-time fleet dashboard.', href: 'https://nextjs.org' },
  { name: 'PostgreSQL', desc: 'JSONB storage — one document per module.', href: 'https://www.postgresql.org' },
  { name: 'Terraform', desc: 'Provisions ReportMate into Azure or AWS.', href: 'https://www.terraform.io' },
  { name: 'Munki', desc: 'macOS managed installs, surfaced in the Installs module.', href: 'https://www.munki.org' },
  { name: 'Cimian', desc: 'Windows managed installs, surfaced in the Installs module.', href: 'https://github.com/windowsadmins/cimian' },
];
---

<Layout title="ReportMate — Open-Source Endpoint Intelligence for Mac & Windows">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-6 py-24 text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white px-4 py-1.5 text-sm text-brand-700 shadow-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
        Open source · Self-host free · macOS + Windows
      </div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl">
        See every endpoint.<br />
        <span class="text-brand-600">Own all of the data.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
        ReportMate is open-source endpoint intelligence for macOS and Windows. Native clients do the heavy
        collection and processing <strong class="font-semibold text-gray-900">on each device</strong>, then stream
        signed events to an API and database <strong class="font-semibold text-gray-900">you control</strong> — no
        agents phoning home to a vendor.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="https://demo.reportmate.app" class="rounded-lg bg-brand-600 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-brand-700">
          Explore the Live Demo
        </a>
        <a href="https://github.com/reportmate" class="rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
          View on GitHub
        </a>
      </div>
      <p class="mt-6 text-sm text-gray-500">
        Deploy to your own Azure or AWS tenant with Terraform — or let us run it for you.
      </p>
    </div>
  </section>

  <!-- Positioning strip -->
  <section class="border-y border-gray-100 bg-white">
    <div class="mx-auto grid max-w-6xl gap-px bg-gray-100 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { stat: '10', label: 'data modules per device' },
        { stat: '2', label: 'first-class platforms: Mac & Windows' },
        { stat: '40+', label: 'versioned REST API endpoints' },
        { stat: '100%', label: 'of your data stays in your cloud' },
      ].map(({ stat, label }) => (
        <div class="bg-white px-6 py-8 text-center">
          <div class="text-3xl font-bold text-brand-600">{stat}</div>
          <div class="mt-1 text-sm text-gray-600">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Ten reports (moved above the diagram, upgraded) -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
          Unified telemetry
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Ten reports on every device.<br class="hidden sm:block" /> The same on Mac and Windows.
        </h2>
        <p class="mt-5 text-lg text-gray-600">
          Every check-in refreshes ten module reports, built and normalized on the endpoint to one shared schema.
          Not two tools bolted together — one genuinely unified fleet view.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
        {modules.map(({ name, short, accent, icon }) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-brand-200 hover:shadow-lg">
            <div class:list={['flex h-11 w-11 items-center justify-center rounded-xl', accent]}>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="h-6 w-6">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="mt-4 font-semibold text-gray-900">{name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">{short}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/features" class="text-sm font-medium text-brand-600 hover:text-brand-700">
          See every field each module collects &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Event-driven & API-first (moved directly under the modules) -->
  <FeatureBlock badge="Event-driven & API-first" title="If the dashboard can show it, your code can fetch it">
    <p>
      ReportMate is built API-first on FastAPI with a full OpenAPI specification. Devices ingest through the same
      documented event API the dashboard reads from. Query a single device, pull bulk fleet analytics, stream
      events, or wire ReportMate into your CMDB, SIEM, or automation.
    </p>
    <ul class="space-y-3 text-base">
      <li class="flex items-start gap-3">
        <span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-400"></span>
        <span>40+ versioned <code class="rounded bg-brand-900 px-1.5 py-0.5 text-sm">/api/v1</code> endpoints with interactive OpenAPI docs</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-400"></span>
        <span>Per-device and bulk fleet queries: hardware, applications, installs, identity, inventory</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-400"></span>
        <span>Real-time event ingestion and a SignalR/WebSocket negotiate endpoint for live updates</span>
      </li>
    </ul>
    <div class="pt-2">
      <a href="/docs" class="inline-block rounded-lg bg-white px-5 py-2.5 text-sm font-medium text-brand-900 hover:bg-gray-100">
        Browse the API reference
      </a>
    </div>
    <div slot="visual" class="rounded-2xl border border-brand-800 bg-brand-900/60 p-6 font-mono text-sm shadow-2xl">
      <div class="mb-3 flex gap-1.5">
        <span class="h-3 w-3 rounded-full bg-red-400"></span>
        <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
        <span class="h-3 w-3 rounded-full bg-green-400"></span>
      </div>
      <pre class="overflow-x-auto text-brand-100"><code>{curlExample}</code></pre>
    </div>
  </FeatureBlock>

  <!-- Architecture diagram -->
  <section id="architecture" class="scroll-mt-20 bg-gray-50 py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center rounded-full border border-brand-200 bg-white px-3 py-1 text-xs font-medium text-brand-700">
          End-to-end &amp; self-hosted
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Own the whole pipeline, end to end</h2>
        <p class="mt-5 text-lg text-gray-600">
          The entire stack — native binaries, event-driven API, JSONB store, real-time push — deploys into your own
          Azure or AWS tenant with Terraform, in an afternoon. No per-layer vendors to license, every layer yours to
          audit and extend, and your fleet data never leaves infrastructure you control.
        </p>
      </div>

      <!-- Five-stage pipeline stepper -->
      <ol class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {[
          { n: '1', verb: 'Collect', where: 'on the device', tone: 'device', desc: 'osquery + native OS tooling' },
          { n: '2', verb: 'Transmit', where: 'on the device', tone: 'device', desc: 'signed event over HTTPS' },
          { n: '3', verb: 'Ingest', where: 'in your cloud', tone: 'cloud', desc: 'FastAPI /api/v1/events' },
          { n: '4', verb: 'Store', where: 'in your cloud', tone: 'cloud', desc: 'PostgreSQL, JSONB per module' },
          { n: '5', verb: 'Read', where: 'web + native apps', tone: 'read', desc: 'dashboard, native apps & API' },
        ].map(({ n, verb, where, tone, desc }) => (
          <li class="relative rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
            <div class="flex items-center gap-2">
              <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand-600 text-sm font-bold text-white">{n}</span>
              <span class="font-semibold text-gray-900">{verb}</span>
            </div>
            <div class:list={[
              'mt-3 inline-block rounded-full px-2 py-0.5 text-xs font-medium',
              tone === 'device' ? 'bg-blue-50 text-blue-700' : tone === 'cloud' ? 'bg-emerald-50 text-emerald-700' : 'bg-violet-50 text-violet-700',
            ]}>{where}</div>
            <p class="mt-2 text-sm text-gray-600">{desc}</p>
          </li>
        ))}
      </ol>

      <div class="mt-12">
        <Mermaid
          code={archDiagram}
          caption="Collection and processing run on the endpoint; storage, real-time push, and reading run in infrastructure you own."
        />
      </div>
    </div>
  </section>

  <!-- Right tool at every layer (engineering principle) -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
          Engineering principle
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">The right tool at every layer</h2>
        <p class="mt-5 text-lg text-gray-600">
          A deliberate split: compiled native binaries where reliability is everything, Python where iteration speed
          is. The interpreter never touches the endpoint.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2">
        <div class="rounded-2xl border border-blue-100 bg-blue-50/40 p-8">
          <div class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
            On the device
          </div>
          <h3 class="mt-4 text-xl font-semibold text-gray-900">Native compiled binaries — no Python</h3>
          <p class="mt-3 text-gray-600">
            Collection is Swift on macOS and C#/.NET on Windows, driven by osquery and native OS tooling. There is no
            Python runtime to install, pin, or repair across thousands of endpoints — a signed, compiled binary just
            runs. Local collection has to be bulletproof, so we keep an interpreter out of that path entirely.
          </p>
          <ul class="mt-5 space-y-2 text-sm text-gray-600">
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-blue-500"></span><span>Swift (macOS) and C#/.NET (Windows), signed and notarized</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-blue-500"></span><span>osquery + native APIs, with bash/jq fallbacks — never Python</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-blue-500"></span><span>Nothing to maintain on the endpoint but a single binary</span></li>
          </ul>
        </div>

        <div class="rounded-2xl border border-emerald-100 bg-emerald-50/40 p-8">
          <div class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
            In your cloud
          </div>
          <h3 class="mt-4 text-xl font-semibold text-gray-900">Python &amp; FastAPI — where it shines</h3>
          <p class="mt-3 text-gray-600">
            The API layer is where Python earns its place: FastAPI gives us a typed, OpenAPI-documented event API
            that's fast to extend and a pleasure to integrate against. The trade-off is intentional — rich
            dependencies live in the cloud you control and upgrade on your schedule, never on the endpoint.
          </p>
          <ul class="mt-5 space-y-2 text-sm text-gray-600">
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-emerald-500"></span><span>FastAPI with a full OpenAPI spec and interactive docs</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-emerald-500"></span><span>Runs in a container, provisioned by Terraform on Azure or AWS</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-emerald-500"></span><span>Upgraded centrally — endpoints are unaffected</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why ReportMate -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Built for teams that want control</h2>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        <div class="rounded-2xl border border-gray-100 p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Truly cross-platform</h3>
          <p class="mt-2 text-gray-600">
            One schema, one dashboard, one API for Mac and Windows. No reconciling two products with different data
            models and different bills.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-100 p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Your data, your cloud</h3>
          <p class="mt-2 text-gray-600">
            Self-host or deploy to your own Azure/AWS tenant with the included Terraform. Telemetry never transits a
            vendor's servers. Encrypted in transit, passphrase-authenticated.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-100 p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Open source, no lock-in</h3>
          <p class="mt-2 text-gray-600">
            Source-available under BSL 1.1. Read the code, audit the collection, extend a module, or fork it. Your
            data lives in plain PostgreSQL you can query directly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Built on open source -->
  <section class="border-t border-gray-100 bg-gray-50 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Built on open source</h2>
        <p class="mt-4 text-gray-600">
          ReportMate stands on the shoulders of the tools our community already trusts — and integrates with the
          managed-software systems you may already run.
        </p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {attributions.map(({ name, desc, href }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md"
          >
            <div class="flex items-center justify-between">
              <h3 class="font-semibold text-gray-900">{name}</h3>
              <svg class="h-4 w-4 text-gray-300 transition group-hover:text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-900 py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to take control of your fleet?</h2>
      <p class="mt-4 text-lg text-gray-300">
        Click around the live demo, or deploy your own in an afternoon. Self-host for free, or let us run it.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="https://demo.reportmate.app" class="rounded-lg bg-brand-600 px-6 py-3 text-sm font-medium text-white hover:bg-brand-700">
          Explore the Live Demo
        </a>
        <a href="/pricing" class="rounded-lg border border-gray-600 px-6 py-3 text-sm font-medium text-white hover:bg-gray-800">
          See Pricing
        </a>
      </div>
    </div>
  </section>
</Layout>
