---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ReportMate - Open-Source Endpoint Management">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-6 py-24 text-center">
      <div class="mb-6 inline-flex items-center rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-sm text-brand-700">
        Open Source
      </div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl">
        Endpoint management<br />
        <span class="text-brand-600">that just works</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
        Monitor, manage, and report on your macOS and Windows fleet from a single dashboard.
        Real-time hardware, software, security, and network data -- no agents phoning home to third parties.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a
          href="https://demo.reportmate.app"
          class="rounded-lg bg-brand-600 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-brand-700"
        >
          Try the Live Demo
        </a>
        <a
          href="https://github.com/reportmate"
          class="rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50"
        >
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Value Props -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-gray-900">Everything you need to manage your fleet</h2>
        <p class="mt-4 text-lg text-gray-600">
          Lightweight agents collect data at the source. The dashboard is a reader -- no heavy processing server-side.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-gray-100 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Cross-Platform</h3>
          <p class="mt-2 text-gray-600">
            Native agents for macOS (Swift) and Windows (C#/.NET). Full hardware, software, network, and security data from both platforms.
          </p>
        </div>

        <div class="rounded-xl border border-gray-100 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zm6-4a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zm6-3a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Real-Time Dashboard</h3>
          <p class="mt-2 text-gray-600">
            Next.js dashboard with live fleet overview, device drill-down, hardware inventory, application usage, security posture, and OS distribution.
          </p>
        </div>

        <div class="rounded-xl border border-gray-100 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Security First</h3>
          <p class="mt-2 text-gray-600">
            Encrypted client-to-server communication, passphrase authentication, no third-party data sharing. Self-host for complete control.
          </p>
        </div>

        <div class="rounded-xl border border-gray-100 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">REST API</h3>
          <p class="mt-2 text-gray-600">
            FastAPI backend with OpenAPI docs. 34 versioned endpoints for devices, events, statistics, and fleet management. Build your own integrations.
          </p>
        </div>

        <div class="rounded-xl border border-gray-100 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M5.5 16a3.5 3.5 0 01-.369-6.98 4 4 0 117.753-1.977A4.5 4.5 0 1113.5 16h-8z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Multi-Cloud</h3>
          <p class="mt-2 text-gray-600">
            Production-ready Terraform modules for both Azure and AWS. Deploy to your preferred cloud or self-host on any infrastructure.
          </p>
        </div>

        <div class="rounded-xl border border-gray-100 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 3a1 1 0 000 2v8a2 2 0 002 2h2.586l-1.293 1.293a1 1 0 101.414 1.414L10 15.414l2.293 2.293a1 1 0 001.414-1.414L12.414 15H15a2 2 0 002-2V5a1 1 0 100-2H3zm11.707 4.707a1 1 0 00-1.414-1.414L10 9.586 8.707 8.293a1 1 0 00-1.414 0l-2 2a1 1 0 101.414 1.414L8 10.414l1.293 1.293a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Data Collection</h3>
          <p class="mt-2 text-gray-600">
            Hardware specs, installed software, OS versions, network interfaces, security status, disk encryption, profiles, and printers -- all collected at the endpoint.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-950 py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to take control of your fleet?</h2>
      <p class="mt-4 text-lg text-brand-200">
        Deploy in minutes. Self-host for free, or let us run it for you.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a
          href="https://demo.reportmate.app"
          class="rounded-lg bg-white px-6 py-3 text-sm font-medium text-brand-900 hover:bg-gray-100"
        >
          Try the Live Demo
        </a>
        <a
          href="/pricing"
          class="rounded-lg border border-brand-400 px-6 py-3 text-sm font-medium text-white hover:bg-brand-900"
        >
          View Pricing
        </a>
      </div>
    </div>
  </section>
</Layout>
