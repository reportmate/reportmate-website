---
import Layout from '../layouts/Layout.astro';
---

<Layout title="API Documentation — ReportMate" description="Interactive REST API reference for ReportMate: 40+ versioned endpoints for devices, fleet analytics, events, and statistics." hideFooter={true}>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@stoplight/elements@8.4.4/styles.min.css"
    integrity="sha384-oYu9Au1JU1Sd5Za5LYSepn+Sofm8uvVdUCxLWbJYesNAS72Y7G/gQ0pjiB6wyf1Z"
    crossorigin="anonymous"
  />
  <style is:inline>
    .sl-elements,
    elements-api {
      --color-primary: #0074c7;
      --color-primary-dark: #015da1;
      --color-primary-darker: #064f85;
      --color-primary-light: #36adf8;
      --color-primary-tint: #e0effe;
      --color-link: #0074c7;
      --color-link-dark: #015da1;
    }
  </style>

  <div class="h-[calc(100vh-4rem)]">
    <elements-api
      apiDescriptionUrl="/openapi.json"
      router="hash"
      layout="sidebar"
      class="block h-full"
    ></elements-api>
  </div>

  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/@stoplight/elements@8.4.4/web-components.min.js"
    integrity="sha384-qmzC5RdXRK/xaavHo3VDUMIFUUroqgeUVjfkWP2rQn/fHPjyyBdX3M164EvniiZ2"
    crossorigin="anonymous"
  ></script>
</Layout>
