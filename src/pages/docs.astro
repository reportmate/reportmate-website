---
import Layout from '../layouts/Layout.astro';
---

<Layout title="API Documentation — ReportMate" description="Interactive REST API reference for ReportMate: 40+ versioned endpoints for devices, fleet analytics, events, and statistics.">
  <section class="border-b border-gray-100 bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-6 py-12">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">REST API</h1>
      <p class="mt-3 max-w-3xl text-gray-600">
        ReportMate is API-first. The dashboard reads from the same FastAPI service your integrations can — 40+
        versioned endpoints under <code class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-sm">/api/v1</code>,
        fully described by OpenAPI.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
        <span class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-1.5">
          <span class="font-semibold text-gray-900">Base URL</span>
          <code class="font-mono text-brand-700">https://api.reportmate.app</code>
        </span>
        <span class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-1.5">
          <span class="font-semibold text-gray-900">Auth</span>
          <code class="font-mono text-xs text-gray-600">X-Client-Passphrase</code>
        </span>
        <a href="/openapi.json" class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-3 py-1.5 font-medium text-gray-700 hover:bg-gray-50">
          OpenAPI spec (JSON)
        </a>
        <a href="https://demo.reportmate.app" class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-3 py-1.5 font-medium text-gray-700 hover:bg-gray-50">
          See it powering the live demo
        </a>
      </div>
    </div>
  </section>

  <div id="redoc"></div>

  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/redoc@2.5.0/bundles/redoc.standalone.js"
    integrity="sha384-4vOjrBu7SuDWXcAw1qFznVLA/sKL+0l4nn+J1HY8w7cpa6twQEYuh4b0Cwuo7CyX"
    crossorigin="anonymous"
  ></script>
  <script is:inline>
    (function mount() {
      if (window.Redoc && window.Redoc.init) {
        window.Redoc.init(
          '/openapi.json',
          {
            scrollYOffset: 64,
            expandResponses: '200',
            hideLoading: false,
            theme: {
              colors: { primary: { main: '#0074c7' } },
              typography: {
                fontFamily: 'ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif',
                headings: { fontWeight: '700' },
                code: { fontFamily: 'ui-monospace, SFMono-Regular, Menlo, monospace' },
              },
              sidebar: { width: '280px' },
            },
          },
          document.getElementById('redoc')
        );
      } else {
        setTimeout(mount, 50);
      }
    })();
  </script>
</Layout>
