---
import Layout from '../layouts/Layout.astro';
---

<Layout title="API Documentation — ReportMate" description="Interactive REST API reference for ReportMate: 40+ versioned endpoints for devices, fleet analytics, events, and statistics." hideFooter={true}>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@stoplight/elements@8.4.4/styles.min.css"
    integrity="sha384-oYu9Au1JU1Sd5Za5LYSepn+Sofm8uvVdUCxLWbJYesNAS72Y7G/gQ0pjiB6wyf1Z"
    crossorigin="anonymous"
  />
  <style is:inline>
    .sl-elements,
    elements-api {
      --color-primary: #0074c7;
      --color-primary-dark: #015da1;
      --color-primary-darker: #064f85;
      --color-primary-light: #36adf8;
      --color-primary-tint: #e0effe;
      --color-link: #0074c7;
      --color-link-dark: #015da1;
    }
    /* Belt-and-suspenders: keep the embed light even if Stoplight resolves a dark theme. */
    .sl-elements[data-theme='dark'],
    elements-api[data-theme='dark'],
    [data-theme='dark'] .sl-elements {
      color-scheme: light;
    }
  </style>

  <!--
    Stoplight Elements auto-detects the OS theme via matchMedia('(prefers-color-scheme: dark)')
    and renders an unreadable dark sidebar/panels that clash with the rest of the site, which is
    light-only by design. Force that one query to report light before the web component upgrades,
    so the docs always render in the light theme. All other media queries pass through untouched.
  -->
  <script is:inline>
    (function () {
      var original = window.matchMedia ? window.matchMedia.bind(window) : null;
      if (!original) return;
      window.matchMedia = function (query) {
        if (typeof query === 'string' && query.indexOf('prefers-color-scheme') !== -1) {
          return {
            matches: false,
            media: query,
            onchange: null,
            addListener: function () {},
            removeListener: function () {},
            addEventListener: function () {},
            removeEventListener: function () {},
            dispatchEvent: function () { return false; },
          };
        }
        return original(query);
      };
    })();
  </script>

  <div class="h-[calc(100vh-4rem)]">
    <elements-api
      apiDescriptionUrl="/openapi.json"
      router="hash"
      layout="sidebar"
      class="block h-full"
    ></elements-api>
  </div>

  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/@stoplight/elements@8.4.4/web-components.min.js"
    integrity="sha384-qmzC5RdXRK/xaavHo3VDUMIFUUroqgeUVjfkWP2rQn/fHPjyyBdX3M164EvniiZ2"
    crossorigin="anonymous"
  ></script>
</Layout>
