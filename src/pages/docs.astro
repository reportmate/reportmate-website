---
import Layout from '../layouts/Layout.astro';

const groups = [
  { tag: 'Devices', desc: 'Per-device detail, fast info, events, install logs, usage history, and any single module document.' },
  { tag: 'Fleet', desc: 'Bulk analytics across the fleet — hardware, applications, installs, identity, inventory — plus distributions and filters.' },
  { tag: 'Events', desc: 'Ingest device check-ins and retrieve the event stream and raw payloads.' },
  { tag: 'Statistics', desc: 'Pre-aggregated dashboard data and install statistics.' },
  { tag: 'Settings', desc: 'Tenant settings and dynamic inventory key discovery.' },
  { tag: 'Health', desc: 'Liveness checks and the SignalR negotiate endpoint for real-time updates.' },
];
---

<Layout title="API Documentation — ReportMate" description="Interactive REST API reference for ReportMate: 40+ versioned endpoints for devices, fleet analytics, events, and statistics.">
  <section class="border-b border-gray-100 bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900">REST API</h1>
      <p class="mt-4 max-w-3xl text-lg text-gray-600">
        ReportMate is API-first. The dashboard reads from the same FastAPI service your integrations can — 40+
        versioned endpoints under <code class="rounded bg-gray-100 px-1.5 py-0.5 text-base font-mono">/api/v1</code>,
        fully described by OpenAPI.
      </p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-gray-200 bg-white p-5">
          <h3 class="text-sm font-semibold text-gray-900">Base URL</h3>
          <code class="mt-2 block text-sm text-brand-700">https://api.reportmate.app</code>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-5">
          <h3 class="text-sm font-semibold text-gray-900">Authentication</h3>
          <p class="mt-2 text-sm text-gray-600">
            <code class="rounded bg-gray-100 px-1 py-0.5 font-mono text-xs">X-Client-Passphrase</code> header
            (clients), an internal secret (service-to-service), or Azure Managed Identity.
          </p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-5">
          <h3 class="text-sm font-semibold text-gray-900">Format</h3>
          <p class="mt-2 text-sm text-gray-600">JSON over HTTPS. Versioned, OpenAPI-described, rate-limited.</p>
        </div>
      </div>

      <div class="mt-8">
        <h3 class="text-sm font-semibold text-gray-900">Endpoint groups</h3>
        <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {groups.map(({ tag, desc }) => (
            <div class="rounded-lg border border-gray-100 bg-white p-4">
              <span class="text-sm font-semibold text-gray-900">{tag}</span>
              <p class="mt-1 text-xs leading-relaxed text-gray-600">{desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/openapi.json" class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
          OpenAPI spec (JSON)
        </a>
        <a href="https://demo.reportmate.app" class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
          See it powering the live demo
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-12">
    <h2 class="text-xl font-bold text-gray-900">Interactive reference</h2>
    <p class="mt-2 text-sm text-gray-600">Generated from the live OpenAPI specification.</p>
    <div id="scalar-api-reference" class="mt-6"></div>
  </section>

  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/@scalar/api-reference@1.60.0"
    integrity="sha384-4BdmZQQTc462+ocGPo+GP3Hi/eQjMQTmNkSU9J5w3FD6hGUEmU2PqNRnbklONt4R"
    crossorigin="anonymous"
  ></script>
  <script is:inline>
    (function mount() {
      if (window.Scalar && window.Scalar.createApiReference) {
        window.Scalar.createApiReference('#scalar-api-reference', { url: '/openapi.json' });
      } else {
        setTimeout(mount, 50);
      }
    })();
  </script>
</Layout>
