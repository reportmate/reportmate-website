---
import Layout from '../layouts/Layout.astro';
---

<Layout title="API Documentation — ReportMate" description="Interactive REST API reference for ReportMate: 40+ versioned endpoints for devices, fleet analytics, events, and statistics." hideFooter={true}>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@stoplight/elements@8.4.4/styles.min.css"
    integrity="sha384-oYu9Au1JU1Sd5Za5LYSepn+Sofm8uvVdUCxLWbJYesNAS72Y7G/gQ0pjiB6wyf1Z"
    crossorigin="anonymous"
  />
  <style is:inline>
    .sl-elements,
    elements-api {
      --color-link: #0074c7;
      --color-link-dark: #015da1;
    }
    [data-theme='dark'] .sl-elements,
    [data-theme='dark'] elements-api {
      --color-link: #36adf8;
      --color-link-dark: #66c7ff;
    }
    /* Match the docs chrome (page background + header) to the active theme so the
       Stoplight panel doesn't sit on a white page in dark mode. */
    [data-theme='dark'] body {
      background-color: #0d1117;
    }
  </style>

  <!--
    Stoplight Elements ships a dark theme but doesn't auto-follow the OS; it reads a `data-theme`
    attribute on an ancestor. Mirror the OS `prefers-color-scheme` onto <html data-theme> so the
    docs render Stoplight's coherent dark theme in dark mode and its light theme otherwise.
    Run before the web component upgrades so it picks the right theme on first paint.
  -->
  <script is:inline>
    (function () {
      var mq = window.matchMedia('(prefers-color-scheme: dark)');
      function apply() {
        document.documentElement.setAttribute('data-theme', mq.matches ? 'dark' : 'light');
      }
      apply();
      if (mq.addEventListener) mq.addEventListener('change', apply);
      else if (mq.addListener) mq.addListener(apply);
    })();
  </script>

  <div class="h-[calc(100vh-4rem)]">
    <elements-api
      apiDescriptionUrl="/openapi.json"
      router="hash"
      layout="sidebar"
      class="block h-full"
    ></elements-api>
  </div>

  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/@stoplight/elements@8.4.4/web-components.min.js"
    integrity="sha384-qmzC5RdXRK/xaavHo3VDUMIFUUroqgeUVjfkWP2rQn/fHPjyyBdX3M164EvniiZ2"
    crossorigin="anonymous"
  ></script>
</Layout>
