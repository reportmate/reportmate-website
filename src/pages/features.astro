---
import Layout from '../layouts/Layout.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import { modules } from '../data/modules.js';

const apiGroups = [
  { tag: 'Devices', desc: 'Per-device detail, fast info, events, install logs, usage history, and any single module document.', method: 'GET', path: '/api/v1/device/{serial}/modules/{module}' },
  { tag: 'Fleet', desc: 'Bulk analytics across the whole fleet: hardware, applications, installs, identity, inventory, plus distributions and filters.', method: 'GET', path: '/api/v1/devices/hardware' },
  { tag: 'Events', desc: 'Ingest device check-ins and retrieve the event stream and raw payloads.', method: 'POST', path: '/api/v1/events' },
  { tag: 'Statistics', desc: 'Pre-aggregated dashboard data and install statistics for at-a-glance fleet health.', method: 'GET', path: '/api/v1/dashboard' },
  { tag: 'Settings', desc: 'Tenant settings and dynamic inventory key discovery.', method: 'GET', path: '/api/v1/settings' },
  { tag: 'Health', desc: 'Liveness checks and the SignalR negotiate endpoint that powers real-time updates.', method: 'GET', path: '/api/v1/negotiate' },
];
---

<Layout title="Features — ReportMate" description="Ten data modules collected on-device, an event-driven REST API, a real-time dashboard, and Terraform deployment for Macintosh and Windows fleets.">
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-6 py-20 text-center">
      <div class="inline-flex items-center rounded-full border border-brand-200 bg-white px-3 py-1 text-xs font-medium text-brand-700 shadow-sm">
        Everything it collects
      </div>
      <h1 class="mt-5 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">Ten modules. One schema.<br class="hidden sm:block" /> Macintosh and Windows.</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-gray-600">
        Every module is collected and normalized at the endpoint, then stored as its own JSONB document and served
        through the API. Here is exactly what lands in each one.
      </p>
    </div>
  </section>

  <!-- Module deep-dive -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-6 md:grid-cols-2">
        {modules.map(({ name, fields, accent, icon }, i) => (
          <div class="flex gap-5 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
            <div class:list={['flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl', accent]}>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="h-6 w-6">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <div>
              <div class="flex items-baseline gap-2">
                <span class="text-xs font-semibold text-gray-400">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="font-semibold text-gray-900">{name}</h3>
              </div>
              <p class="mt-1.5 text-sm leading-relaxed text-gray-600">{fields}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Real-time / event-driven -->
  <FeatureBlock badge="Real-time & event-driven" title="The fleet view updates as devices report in" reverse={true}>
    <p>
      Every client check-in is an event. The API ingests it, writes the module documents to PostgreSQL, and pushes
      an update to connected dashboards over SignalR/WebSocket — so what you see reflects reality without polling.
    </p>
    <ul class="space-y-3 text-base">
      <li class="flex items-start gap-3"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-400"></span><span>Scheduled collection: launchd on Macintosh, service + scheduled task on Windows</span></li>
      <li class="flex items-start gap-3"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-400"></span><span>Event payloads over HTTPS, authenticated per client</span></li>
      <li class="flex items-start gap-3"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-400"></span><span>Raw payloads retained and retrievable per event for audit and debugging</span></li>
    </ul>
    <div slot="visual" class="rounded-2xl border border-brand-800 bg-brand-900/60 p-6 font-mono text-sm shadow-2xl">
      <div class="space-y-2 text-brand-100">
        <div><span class="text-green-400">POST</span> /api/v1/events <span class="text-brand-300">→ 202 Accepted</span></div>
        <div class="text-brand-300">device C02XL0ABJGH7 · 10 modules</div>
        <div class="border-t border-brand-800 pt-2 text-brand-300">push → dashboard</div>
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 animate-pulse rounded-full bg-green-400"></span>
          <span>fleet view updated · 0.4s</span>
        </div>
      </div>
    </div>
  </FeatureBlock>

  <!-- REST API -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-2xl font-bold text-gray-900">A documented REST API for everything</h2>
      <p class="mt-3 max-w-3xl text-gray-600">
        FastAPI with a full OpenAPI specification — 40+ versioned endpoints under <code class="rounded bg-gray-100 px-1.5 py-0.5 text-sm">/api/v1</code>.
        Authenticated with <code class="rounded bg-gray-100 px-1.5 py-0.5 text-sm">X-Client-Passphrase</code>, an
        internal secret for service-to-service, or Azure Managed Identity.
      </p>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {apiGroups.map(({ tag, desc, method, path }) => (
          <div class="flex flex-col rounded-2xl border border-gray-100 p-6 shadow-sm">
            <h3 class="font-semibold text-gray-900">{tag}</h3>
            <p class="mt-2 flex-1 text-sm text-gray-600">{desc}</p>
            <div class="mt-4 flex items-start gap-2 rounded-lg bg-slate-900 px-3 py-2.5">
              <span class:list={[
                'flex-shrink-0 rounded px-1.5 py-0.5 text-[10px] font-bold tracking-wide text-white',
                method === 'POST' ? 'bg-blue-600' : 'bg-emerald-600',
              ]}>{method}</span>
              <code class="break-all font-mono text-xs leading-relaxed text-slate-200">{path}</code>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10">
        <a href="/docs" class="text-sm font-medium text-brand-600 hover:text-brand-700">Open the interactive API reference &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Architecture detail -->
  <section class="border-t border-gray-100 bg-gray-50 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-2xl font-bold text-gray-900">Architecture</h2>
      <div class="mt-8 grid gap-8 md:grid-cols-2">
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Client agents</h3>
          <ul class="mt-4 space-y-3 text-gray-600">
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500"></span><span><strong>Macintosh:</strong> native Swift binary, launchd-scheduled, osquery + system APIs, signed &amp; notarized</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500"></span><span><strong>Windows:</strong> C#/.NET binary, Windows service + scheduled task, osquery integration, signed</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500"></span><span>Collection is a single self-contained binary — quick to deploy, nothing to maintain</span></li>
          </ul>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900">Server stack</h3>
          <ul class="mt-4 space-y-3 text-gray-600">
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500"></span><span><strong>API:</strong> FastAPI with versioned REST endpoints and OpenAPI docs</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500"></span><span><strong>Frontend:</strong> Next.js, server-rendered, reader-only with real-time updates</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500"></span><span><strong>Database:</strong> PostgreSQL with JSONB, one document per module</span></li>
            <li class="flex items-start gap-2"><span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500"></span><span><strong>Infrastructure:</strong> Terraform modules for Azure and AWS</span></li>
          </ul>
        </div>
      </div>
      <p class="mt-6 text-sm text-gray-500">
        See how the layers connect on the <a href="/#architecture" class="font-medium text-brand-600 hover:text-brand-700">architecture diagram</a>.
      </p>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-2xl font-bold text-gray-900">On the roadmap</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-dashed border-gray-300 p-6">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-600">Coming soon</div>
          <h3 class="mt-2 font-semibold text-gray-900">Native dashboard apps</h3>
          <p class="mt-2 text-sm text-gray-600">First-party Macintosh and Windows apps for browsing your fleet natively, built on the same REST API.</p>
        </div>
        <div class="rounded-2xl border border-dashed border-gray-300 p-6">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-600">Coming soon</div>
          <h3 class="mt-2 font-semibold text-gray-900">Self-service cloud portal</h3>
          <p class="mt-2 text-sm text-gray-600">Sign up, provision a managed tenant, and manage billing without leaving the browser.</p>
        </div>
        <div class="rounded-2xl border border-dashed border-gray-300 p-6">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-600">Exploring</div>
          <h3 class="mt-2 font-semibold text-gray-900">More integrations</h3>
          <p class="mt-2 text-sm text-gray-600">Webhooks and turnkey connectors for CMDB, SIEM, and asset systems on top of the existing API.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
