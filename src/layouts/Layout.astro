---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Open-source, cross-platform endpoint intelligence for Macintosh and Windows fleets. Native on-device collection, a real-time dashboard, and a full REST API. Self-host free or run it managed.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/reportmate-logo.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0074c7" />
    <meta name="color-scheme" content="light" />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="mask-icon" href="/mask-icon.svg" color="#0074c7" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReportMate" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <nav class="sticky top-0 z-50 border-b border-gray-200/70 bg-white/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/reportmate-logo.png" alt="ReportMate" class="h-9 w-9" width="36" height="36" />
          <span class="flex flex-col leading-tight">
            <span class="text-base font-bold tracking-tight text-gray-900">ReportMate</span>
            <span class="text-[11px] font-medium text-gray-500">Endpoint Monitoring</span>
          </span>
        </a>
        <div class="hidden items-center gap-1 md:flex">
          <a href="/features" class="rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900">Features</a>
          <a href="/pricing" class="rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900">Pricing</a>
          <a href="/docs" class="rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900">API Docs</a>
        </div>
        <div class="flex items-center gap-1.5">
          <a
            href="https://github.com/reportmate"
            class="inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
            GitHub
          </a>
          <a
            href="https://demo.reportmate.app"
            class="group inline-flex items-center gap-1.5 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm ring-1 ring-inset ring-white/10 transition hover:bg-brand-700 hover:shadow"
          >
            Try the Demo
            <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-100 bg-gray-50">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="grid gap-8 md:grid-cols-[1.6fr_1fr_1fr_1fr]">
          <div class="md:pr-8">
            <div class="flex items-center gap-2.5">
              <img src="/reportmate-logo.png" alt="" class="h-8 w-8" width="32" height="32" />
              <span class="flex flex-col leading-tight">
                <span class="font-bold text-gray-900">ReportMate</span>
                <span class="text-[11px] font-medium text-gray-500">Endpoint Monitoring</span>
              </span>
            </div>
            <p class="mt-3 max-w-xs text-sm text-gray-600">
              Open-source endpoint intelligence for Macintosh and Windows fleets. Collect everything on-device,
              read it from one dashboard.
            </p>
          </div>
          <div>
            <h4 class="text-sm font-semibold text-gray-900">Product</h4>
            <ul class="mt-3 space-y-2 text-sm text-gray-600">
              <li><a href="/features" class="hover:text-gray-900">Features</a></li>
              <li><a href="/pricing" class="hover:text-gray-900">Pricing</a></li>
              <li><a href="/docs" class="hover:text-gray-900">API Docs</a></li>
              <li><a href="https://demo.reportmate.app" class="hover:text-gray-900">Live Demo</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-semibold text-gray-900">Resources</h4>
            <ul class="mt-3 space-y-2 text-sm text-gray-600">
              <li><a href="/docs" class="hover:text-gray-900">REST API Reference</a></li>
              <li><a href="https://github.com/reportmate" class="hover:text-gray-900">GitHub</a></li>
              <li><a href="https://demo.reportmate.app" class="hover:text-gray-900">Live Demo</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-semibold text-gray-900">Deploy</h4>
            <ul class="mt-3 space-y-2 text-sm text-gray-600">
              <li><a href="https://github.com/reportmate" class="hover:text-gray-900">Self-Host Guide</a></li>
              <li><a href="/pricing" class="hover:text-gray-900">ReportMate Cloud</a></li>
              <li><a href="mailto:hello@reportmate.app" class="hover:text-gray-900">Contact Sales</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 border-t border-gray-200 pt-8 text-center text-sm text-gray-500">
          &copy; {new Date().getFullYear()} ReportMate. Open source under BSL 1.1.
        </div>
      </div>
    </footer>
  </body>
</html>
