---
interface Props {
  badge?: string;
  title: string;
  tone?: 'dark' | 'light';
  reverse?: boolean;
}
const { badge, title, tone = 'dark', reverse = false } = Astro.props;
const dark = tone === 'dark';
---

<section class:list={['py-24', dark ? 'bg-brand-950 text-white' : 'bg-white text-gray-900']}>
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class:list={[reverse ? 'lg:order-2' : 'lg:order-1']}>
        {badge && (
          <div
            class:list={[
              'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium',
              dark ? 'border border-brand-700 bg-brand-900 text-brand-200' : 'border border-brand-200 bg-brand-50 text-brand-700',
            ]}
          >
            {badge}
          </div>
        )}
        <h2 class:list={['mt-4 text-3xl font-bold tracking-tight sm:text-4xl', dark ? 'text-white' : 'text-gray-900']}>
          {title}
        </h2>
        <div class:list={['mt-5 space-y-4 text-lg', dark ? 'text-brand-100' : 'text-gray-600']}>
          <slot />
        </div>
      </div>
      <div class:list={[reverse ? 'lg:order-1' : 'lg:order-2']}>
        <slot name="visual" />
      </div>
    </div>
  </div>
</section>
