---
// Subtle sparkline mark — a hint of trending data.
interface Props {
  class?: string;
  color?: string;
  label?: string;
}
const { class: className = 'h-5 w-16', color = '#0074c7', label } = Astro.props;
// Normalized points across a 64x24 viewBox.
const values = [6, 10, 7, 14, 11, 18, 15, 22];
const max = 24;
const stepX = 64 / (values.length - 1);
const pts = values
  .map((v, i) => `${(i * stepX).toFixed(1)},${(max - v).toFixed(1)}`)
  .join(' ');
const last = pts.split(' ').at(-1)!.split(',');
---
<svg
  class={className}
  viewBox="0 0 64 24"
  fill="none"
  role={label ? 'img' : undefined}
  aria-hidden={label ? undefined : 'true'}
  aria-label={label}
>
  <polyline
    points={pts}
    stroke={color}
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <circle cx={last[0]} cy={last[1]} r="2.5" fill={color} />
</svg>
