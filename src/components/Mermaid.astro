---
interface Props {
  code: string;
  caption?: string;
}
const { code, caption } = Astro.props;
---

<figure class="not-prose">
  <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-10">
    <pre class="mermaid flex justify-center text-center">{code}</pre>
  </div>
  {caption && <figcaption class="mt-3 text-center text-sm text-gray-500">{caption}</figcaption>}
</figure>

<script is:inline type="module">
  if (!window.__rmMermaidInit) {
    window.__rmMermaidInit = true;
    const { default: mermaid } = await import(
      'https://cdn.jsdelivr.net/npm/mermaid@11.15.0/dist/mermaid.esm.min.mjs'
    );
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'loose',
      theme: 'base',
      fontFamily:
        'ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif',
      themeVariables: {
        fontSize: '16px',
        primaryColor: '#e0effe',
        primaryBorderColor: '#0074c7',
        primaryTextColor: '#0b426e',
        lineColor: '#94a3b8',
        clusterBkg: '#f8fafc',
        clusterBorder: '#cbd5e1',
        edgeLabelBackground: '#ffffff',
      },
      flowchart: { htmlLabels: true, curve: 'basis', padding: 22, nodeSpacing: 55, rankSpacing: 80, useMaxWidth: false },
    });
    await mermaid.run({ querySelector: '.mermaid' });
  }
</script>
